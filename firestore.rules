rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to check if user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "ab@gmail.com" || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin");
    }


    // Users Collection
    match /users/{userId} {
      allow read: if true; // Public profiles for vendors/freelancers (and Admins need to list them)
      allow create: if isOwner(userId); // Users create their own profile on signup
      allow update: if isOwner(userId) || isAdmin(); // Users update their own, Admins can update any
      allow delete: if isAdmin();
      
      // Employees Subcollection (Company Dashboard)
      match /employees/{employeeId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      // Freelancer Subcollections
      match /training_courses/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /requested_courses/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /jd_applications/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /earnings_history/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Projects Collection
    match /projects/{projectId} {
      allow read: if true; // Projects are generally public
      allow create: if isAuthenticated();
      allow update: if (isAuthenticated() && (resource.data.clientId == request.auth.uid)) || isAdmin();
      allow delete: if (isAuthenticated() && (resource.data.clientId == request.auth.uid)) || isAdmin();
    }

    // Products Collection (Listings)
    match /products/{productId} {
      allow read: if true; // Publicly visible
      allow create: if isAuthenticated(); // Authenticated users (Sellers/Vendors) can create
      allow update, delete: if (isAuthenticated() && resource.data.sellerId == request.auth.uid) || isAdmin(); // Owner or Admin
    }

    // Orders Collection
    match /orders/{orderId} {
      // Admin can list/count all orders
      allow list: if isAdmin();
      
      // Admin can read single, User can read own single
      allow get: if isAdmin() || (isAuthenticated() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid
      ));
      
      // Implicitly, users CAN list their own orders IF the query filters by buyerId/userId/sellerId.
      // But we need to explicit rule for that?
      // "list" rules generally don't have access to resource.data unless the query filters.
      // So checking resource.data in a "list" rule enforces that the query MUST filter by that field.
      allow list: if isAuthenticated() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid
      );
      
      // Authenticated users can create orders
      allow create: if isAuthenticated() && (
        request.resource.data.buyerId == request.auth.uid || 
        request.resource.data.userId == request.auth.uid
      );
      
      // Buyers and Sellers can update (e.g., status changes), Admins can update
      allow update: if isAdmin() || (isAuthenticated() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid
      ));
    }

    // Chat Sessions Collection (New ChatService)
    match /chatSessions/{sessionId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

      match /messages/{messageId} {
        allow read, write: if isAuthenticated(); // Simplified for POC, ideally check parent ownership
      }
    }

    // Legacy Chats Collection (if still used)
    match /chats/{chatId} {
      // Users can read/write if they are in the participants list
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated() && (request.auth.uid in resource.data.participants);
      
      // Messages Subcollection
      match /messages/{messageId} {
        // Allow if user is a participant of the parent chat
        allow read, write: if isAuthenticated() && 
           request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Payouts Collection
    match /payouts/{payoutId} {
      // Only the recipient (seller/vendor) can read their payouts
      allow read: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      
      // Allow sellers to request payouts
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      
      // Allow sellers to update their payouts (e.g. edit details before processing)
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      
      // Delete if needed
      allow delete: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated(); // Allow creating notifications for users
    }

    // Tickets Collection
    match /tickets/{ticketId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Training Requests Collection
    match /training_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Advertisements Collection (Renamed from 'ads' to match service)
    match /ads/{adId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
    }

    // Reviews Collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }

    // Sub Admins Collection
    match /sub_admins/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Support Agents Collection
    match /support_agents/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
