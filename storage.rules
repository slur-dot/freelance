rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    match /avatars/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isImage() && isUnder5MB() &&
        fileName.matches('.*' + request.auth.uid + '.*');
    }

    match /profile_images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == userId &&
        isImage() && isUnder5MB();
    }

    match /ads/avatars/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isImage() && isUnder5MB() &&
        fileName.matches('.*' + request.auth.uid + '.*');
    }

    match /ads/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isImage() && isUnder5MB();
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isImage() && isUnder5MB();
    }

    match /company-avatars/{companyId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == companyId &&
        isImage() && isUnder5MB();
    }

    match /client-avatars/{clientId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == clientId &&
        isImage() && isUnder5MB();
    }

    match /partnerships/{allPaths=**} {
      allow create: if isAuthenticated() && isUnder5MB();
      allow read: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /courses/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && request.resource.size < 500 * 1024 * 1024;
    }
  }
}
